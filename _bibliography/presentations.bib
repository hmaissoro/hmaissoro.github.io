  author={Maissoro, Hassan},
 abstract={We study the local regularity of weakly dependent functional time series, under $L^p-m$-approximability assumptions.
  The sample paths are observed with error at possibly random, design points.
  Non-asymptotic concentration bounds of the regularity estimators are derived.
  As an application, we build nonparametric mean and autocovariance functions estimators that adapt to the regularity of the sample paths and the design which can be sparse or dense.
